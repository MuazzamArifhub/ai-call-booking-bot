# ============================================================
# AI Call Booking Bot - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control!
# ============================================================

# --- App ---
APP_NAME="AI Call Booking Bot"
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret

# --- Database ---
# Development: SQLite (no setup needed)
DATABASE_URL=sqlite:///./ai_booking.db
# Production: PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_booking

# --- Twilio (get free trial at https://twilio.com) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+12065551234

# --- OpenAI (get free credits at https://platform.openai.com) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# --- ChromaDB (local vector store, no signup needed) ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=call_transcripts

# --- Training pipeline ---
TRANSCRIPTS_DIR=./data/transcripts
TRAINING_OUTPUT_DIR=./data/training
TRAINING_MIN_QUALITY_SCORE=0.7

# --- Recording & consent ---
RECORD_CALLS=false
RECORDING_RETENTION_DAYS=90

# --- Public URL (for Twilio webhooks) ---
# Dev: use ngrok - run `ngrok http 8000` and paste the https URL
# Prod: your deployed app URL
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok.io
